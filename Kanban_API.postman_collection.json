{
  "info": {
    "name": "Kanban Backend API",
    "description": "Postman collection for the Kanban Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test1@example.com\",\n  \"password\": \"TestPass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {\n",
                  "    var data = pm.response.json();\n",
                  "    pm.collectionVariables.set('token', data.token);\n",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test1@example.com\",\n  \"password\": \"TestPass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My New Project\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/projects",
              "host": ["{{base_url}}"],
              "path": ["projects"]
            }
          }
        },
        {
          "name": "Get Projects",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
            },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/projects",
              "host": ["{{base_url}}"],
              "path": ["projects"]
            }
          }
        }
      ]
    },
    {
      "name": "Boards",
      "item": [
        {
          "name": "Get Board",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
            },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/boards/1",
              "host": ["{{base_url}}"],
              "path": ["boards", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Columns",
      "item": [
        {
          "name": "Create Column",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"boardId\": 1,\n  \"name\": \"Todo\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/columns",
              "host": ["{{base_url}}"],
              "path": ["columns"]
            }
          }
        },
        {
          "name": "Update Column",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
            },
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"In Progress\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/columns/1",
              "host": ["{{base_url}}"],
              "path": ["columns", "1"]
            }
          }
        },
        {
          "name": "Delete Column",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
            },
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/columns/1",
              "host": ["{{base_url}}"],
              "path": ["columns", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"columnId\": 1,\n  \"title\": \"Implement login\",\n  \"description\": \"Write user authentication logic\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["tasks"]
            }
          }
        },
        {
          "name": "Get Tasks by Board",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
            },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/tasks?boardId=1",
              "host": ["{{base_url}}"],
              "path": ["tasks"],
              "query": [
                { "key": "boardId", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
            },
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Task Title\",\n  \"description\": \"New description\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tasks/1",
              "host": ["{{base_url}}"],
              "path": ["tasks", "1"]
            }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
            },
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/tasks/1",
              "host": ["{{base_url}}"],
              "path": ["tasks", "1"]
            }
          }
        },
        {
          "name": "Move Task",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ]
            },
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"toColumnId\": 1,\n  \"newOrder\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/tasks/1/move",
              "host": ["{{base_url}}"],
              "path": ["tasks", "1", "move"]
            }
          }
        }
      ]
    }
  ]
}
